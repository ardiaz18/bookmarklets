// Bookmarklet para scrapear los resultados de la serp (1a pag) en un vistazo. Minificar antes de copypaste en marcadores.
// Importante: El DOM de google es dinamico y este bookmarklet requiere actualización constante.

javascript:(function(){try{var ID='alicia-serp-mini';var old=document.getElementById(ID);if(old)old.remove();function clean(t){return String(t||'').replace(/[\u200B-\u200D\uFEFF]/g,'').replace(/\s+/g,' ').trim()}function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}function norm(u){try{var x=new URL(u);if(/google\./i.test(x.hostname)&&x.pathname==='/url'){u=x.searchParams.get('q')||x.searchParams.get('url')||u;x=new URL(u)}x.hash='';if(x.pathname.endsWith('/'))x.pathname=x.pathname.slice(0,-1);return x.toString()}catch(e){return u}}function isHttp(u){return /^https?:\/\//i.test(u)}function isGoogleInternal(u){try{var x=new URL(u);if(!/google\./i.test(x.hostname))return false;if(x.pathname==='/url'||x.pathname==='/imgres')return false;return true}catch(e){return true}}function domain(u){try{return new URL(u).hostname.replace(/^www\./,'').toLowerCase()}catch(e){return''}}function visible(el){var r=el.getBoundingClientRect(),s=getComputedStyle(el);return s.display!=='none'&&s.visibility!=='hidden'&&s.opacity!=='0'&&r.width>20&&r.height>10}function getAIOUrls(){var out=new Set();var blocks=[];Array.from(document.querySelectorAll('div,section')).forEach(function(el){var txt=clean(el.innerText||'');if(/AI Overview|Resumen creado con IA|Vista creada con IA/i.test(txt))blocks.push(el)});blocks=[...new Set(blocks)];blocks.forEach(function(block){block.querySelectorAll('a[href]').forEach(function(a){var u=norm(a.href||'');if(!u||!isHttp(u)||isGoogleInternal(u))return;out.add(u)})});return out}function getTitle(link){var h3=link.querySelector('h3');if(h3)return clean(h3.innerText);var c=link.closest('div,article,section');if(c){var ph3=c.querySelector('h3');if(ph3)return clean(ph3.innerText)}var aria=clean(link.getAttribute('aria-label')||'');if(aria.length>8&&aria.length<220)return aria;return''}var aio=getAIOUrls();var seen=new Set();var rows=[];Array.from(document.querySelectorAll('a[href]')).forEach(function(a){if(rows.length>=30)return;var u=norm(a.href||'');if(!u||!isHttp(u)||isGoogleInternal(u)||!visible(a))return;var title=getTitle(a);if(!title)return;if(seen.has(u))return;seen.add(u);rows.push({pos:rows.length+1,title:title,url:u,domain:domain(u),aio:aio.has(u)?'Sí':'No'})});var html="<div id='"+ID+"' style='position:fixed;top:4%;left:4%;width:92%;height:88%;z-index:2147483647;background:#fff;border:2px solid #111;overflow:auto;padding:16px;box-sizing:border-box;font-family:Arial,sans-serif;color:#111'><div style='position:sticky;top:0;background:#fff;padding-bottom:10px;border-bottom:1px solid #ddd'><button id='close-"+ID+"' style='position:absolute;top:0;right:0;background:#c62828;color:#fff;border:none;padding:7px 12px;cursor:pointer'>X</button><button id='copy-"+ID+"' style='background:#1565c0;color:#fff;border:none;padding:7px 12px;cursor:pointer;margin-right:8px'>Copy TSV</button><div style='margin-top:14px;font-size:20px;font-weight:bold'>Extractor SERP mini</div><div style='margin-top:6px;font-size:14px'>Resultados: <strong>"+rows.length+"</strong> | URLs detectadas en AIO: <strong>"+aio.size+"</strong></div></div><table id='table-"+ID+"' style='width:100%;border-collapse:collapse;margin-top:12px;font-size:13px'><tr><th style='border:1px solid #999;padding:7px;background:#f0f0f0;text-align:left'>#</th><th style='border:1px solid #999;padding:7px;background:#f0f0f0;text-align:left'>Title</th><th style='border:1px solid #999;padding:7px;background:#f0f0f0;text-align:left'>URL</th><th style='border:1px solid #999;padding:7px;background:#f0f0f0;text-align:left'>Domain</th><th style='border:1px solid #999;padding:7px;background:#f0f0f0;text-align:left'>AI Overview</th></tr>";if(rows.length){rows.forEach(function(r){html+="<tr><td style='border:1px solid #bbb;padding:6px;vertical-align:top'>"+r.pos+"</td><td style='border:1px solid #bbb;padding:6px;vertical-align:top'>"+esc(r.title)+"</td><td style='border:1px solid #bbb;padding:6px;vertical-align:top;word-break:break-word'><a href='"+esc(r.url)+"' target='_blank' rel='noopener noreferrer'>"+esc(r.url)+"</a></td><td style='border:1px solid #bbb;padding:6px;vertical-align:top'>"+esc(r.domain)+"</td><td style='border:1px solid #bbb;padding:6px;vertical-align:top'>"+r.aio+"</td></tr>"})}else{html+="<tr><td colspan='5' style='border:1px solid #bbb;padding:10px'>No se han encontrado resultados válidos.</td></tr>"}html+="</table><div style='margin-top:16px;font-size:13px'><a href='https://github.com/ardiaz18/bookmarklets/' target='_blank' rel='noopener noreferrer'>Ver más bookmarklets</a></div></div>";document.body.insertAdjacentHTML('beforeend',html);document.getElementById('close-'+ID).onclick=function(){document.getElementById(ID).remove()};document.getElementById('copy-'+ID).onclick=function(){var text=Array.from(document.querySelectorAll('#table-'+ID+' tr')).map(function(tr){return Array.from(tr.querySelectorAll('th,td')).map(function(td){return clean(td.innerText)}).join('\t')}).join('\n');var ta=document.createElement('textarea');ta.value=text;document.body.appendChild(ta);ta.select();document.execCommand('copy');ta.remove();alert('Tabla copiada al portapapeles')};}catch(e){alert('Error en el bookmarklet: '+e.message);console.error(e)}})();
